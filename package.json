{
  "name": "ecosphere",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d db",
    "docker:down": "docker compose down",
    "docker:app": "docker compose --profile full up --build -d",
    "docker:reset-db": "docker rm -f ecosphere-db 2>/dev/null; docker compose down -v; docker compose up -d db"
  },
